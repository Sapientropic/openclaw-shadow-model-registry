{
  "providers": {
    "openai-codex": {
      "baseUrl": "https://chatgpt.com/backend-api",
      "api": "openai-codex-responses",
      "models": [
        {
          "id": "gpt-5.4",
          "name": "GPT-5.4",
          "reasoning": true,
          "input": [
            "text",
            "image"
          ],
          "contextWindow": 272000,
          "maxTokens": 272000
        }
      ]
    }
  },
  "agents": {
    "eng": {
      "model": {
        "primary": "openai-codex/gpt-5.4",
        "fallbacks": [
          "zai/glm-5"
        ]
      },
      "allowlist": {
        "openai-codex/gpt-5.4": {}
      },
      "sessionOverrides": {
        "agent:eng:main": {
          "thinkingLevel": "xhigh",
          "reasoningLevel": "off"
        }
      },
      "healthcheck": {
        "prompt": "healthcheck: reply with OK and current provider/model only",
        "expectProvider": "openai-codex",
        "expectModel": "gpt-5.4",
        "expectText": "OK openai-codex/gpt-5.4",
        "timeoutSeconds": 120
      },
      "restoreHealthcheck": {
        "prompt": "healthcheck: reply with OK and current provider/model only",
        "expectProvider": "openai-codex",
        "expectModel": "gpt-5.3-codex",
        "expectText": "OK openai-codex/gpt-5.3-codex",
        "timeoutSeconds": 120
      }
    }
  }
}
